---
import StatsStrip from "../components/StatsStrip.astro";
import siteInfo from "../data/site_info.json";
import SiteLayout from "../layouts/SiteLayout.astro";

const aboutCopy = {
  metaTitle: "Association | Génération Femmes",
  metaDescription:
    "Présentation de Génération Femmes : mission, organisation et engagement local à Evry-Courcouronnes.",
  cardOneDescription:
    "Association de médiation sociale implantée à Evry-Courcouronnes, Génération Femmes agit pour l'accès aux droits, le dialogue et l'autonomie des familles.",
  cardOneNote:
    "En 2024, l'association a rejoint de nouveaux locaux au 112 place Salvador Allende, pour accueillir le public dans de meilleures conditions.",
  cardTwoTitle: "Pilotage et organisation",
  cardTwoDescription:
    "La direction coordonne l'équipe, structure les bilans et porte les orientations du conseil d'administration pour renforcer l'impact de terrain.",
  adultRelayConvention:
    "Dispositif emploi tremplin avec soutien public pour consolider l'action de terrain.",
  statsTitle: "Une association structurée et engagée",
  statsLead: "Des repères solides pour accompagner durablement les habitants.",
  statsDetails: [
    "Présence locale continue à Evry-Courcouronnes.",
    "Participation active à la vie associative.",
    "Un ancrage historique dans le quartier.",
    "Conventions pour soutenir le lien école-famille.",
  ],
};

const page = siteInfo.pages.about;
---

<SiteLayout title={aboutCopy.metaTitle} description={aboutCopy.metaDescription}>
  <section>
    <div class="container about-shell">
      <article class="bubble-card about-card">
        <h1>{siteInfo.association.name}</h1>
        <p class="lead">{siteInfo.association.baseline}</p>
        <p>{aboutCopy.cardOneDescription}</p>
        <p class="program-note">{aboutCopy.cardOneNote}</p>
      </article>

      <article class="bubble-card-alt about-card alt">
        <h2>{aboutCopy.cardTwoTitle}</h2>
        <p>{aboutCopy.cardTwoDescription}</p>
        <ul>
          {
            siteInfo.governance.directorMissions.map((mission) => (
              <li>{mission}</li>
            ))
          }
        </ul>
        <p class="program-note">{aboutCopy.adultRelayConvention}</p>
      </article>
    </div>
  </section>

  <StatsStrip
    title={aboutCopy.statsTitle}
    lead={aboutCopy.statsLead}
    stats={page.stats.items}
  />
</SiteLayout>

<style>
  .about-shell {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .about-card {
    background: var(--surface-soft);
    padding: 2rem;
  }

  h1 {
    font-size: clamp(2rem, 1.6rem + 2vw, 3.3rem);
    margin-bottom: 0.6rem;
  }

  .lead {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.8rem;
  }

  .about-card p {
    color: var(--text-muted);
  }

  .alt h2 {
    margin-bottom: 0.6rem;
  }

  ul {
    margin-top: 0.8rem;
    padding-left: 1.2rem;
  }

  li {
    margin-bottom: 0.35rem;
  }

  .program-note {
    margin-top: 0.9rem;
  }

  @media (max-width: 900px) {
    .about-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
