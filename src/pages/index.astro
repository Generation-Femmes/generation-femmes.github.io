---
import HeroBlock from "../components/HeroBlock.astro";
import ProgramGrid from "../components/ProgramGrid.astro";
import StatsStrip from "../components/StatsStrip.astro";
import type { ImageMetadata } from "astro";
import LogoSmall from "../assets/logo.png";
import siteInfo from "../data/site_info.json";
import SiteLayout from "../layouts/SiteLayout.astro";

type HeroAction = {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
};

const home = siteInfo.pages.home;
const homeCopy = {
  heroDescription:
    "Accueil inconditionnel, porte ouverte, main tendue : Génération Femmes agit chaque jour pour renforcer le lien social, faciliter l'accès aux droits et soutenir durablement les familles.",
  statsTitle: "Des résultats concrets au quotidien",
  statsLead: "Des chiffres issus des rapports d'activité 2023 et 2024.",
  programGridTitle: "Nos piliers d'action",
  programGridLead:
    "Un accompagnement global pour l'autonomie et l'accès aux droits.",
  quoteTitle:
    "La médiation n'est pas seulement une solution technique, c'est un acte d'humanité.",
  quoteText: "Besoin d'aide ou envie de soutenir nos actions ? Parlons-en.",
};

const homePrograms = [
  {
    title: "Médiation sociale",
    description:
      "Accompagnement de proximité pour rétablir le dialogue, faciliter l'accès aux droits et renforcer la confiance.",
    tag: "Cohésion sociale",
  },
  {
    title: "Ateliers socio-linguistiques",
    description:
      "Cours de français pour gagner en autonomie dans les démarches du quotidien et la vie professionnelle.",
    tag: "Autonomie",
  },
  {
    title: "Accompagnement administratif",
    description:
      "Aide pour les titres de séjour, CAF, France Travail, prise de rendez-vous et suivi de dossiers.",
    tag: "Accès aux droits",
  },
  {
    title: "Parentalité et école",
    description:
      "Médiation entre les équipes pédagogiques et les familles pour fluidifier la communication et soutenir la réussite.",
    tag: "Éducation",
  },
];

const assetImageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/**/*.{png,jpg,jpeg,webp,avif,gif}",
  { eager: true },
);

const homeImagePath = String(home.hero.image ?? "").trim();
const resolvedHomeImagePath =
  homeImagePath.startsWith("src/assets/")
    ? homeImagePath.replace("src/assets/", "../assets/")
    : homeImagePath.startsWith("../assets/")
      ? homeImagePath
      : homeImagePath
        ? `../assets/${homeImagePath.replace(/^\/+/, "")}`
        : "";

const resolvedHomeImageModule = assetImageModules[resolvedHomeImagePath];
const heroImage: ImageMetadata = resolvedHomeImageModule?.default ?? LogoSmall;

const homeHeroActions: HeroAction[] = home.hero.actions.map((action) => ({
  ...action,
  variant: action.variant === "secondary" ? "secondary" : "primary",
}));
---

<SiteLayout>
  <HeroBlock
    badge={home.hero.badge}
    title={home.hero.title}
    highlight={home.hero.highlight}
    description={homeCopy.heroDescription}
    image={heroImage}
    imageAlt={siteInfo.association.name}
    actions={homeHeroActions}
  />

  <StatsStrip
    title={homeCopy.statsTitle}
    lead={homeCopy.statsLead}
    stats={home.stats.items}
  />

  <ProgramGrid
    id="actions"
    title={homeCopy.programGridTitle}
    lead={homeCopy.programGridLead}
    programs={homePrograms}
  />

  <section class="quote-cta">
    <div class="container">
      <div class="cta-box bubble-card">
        <h2>{homeCopy.quoteTitle}</h2>
        <p>{homeCopy.quoteText}</p>
        <div class="cta-links">
          {
            home.quoteCta.actions.map((action) => (
              <a
                class={`btn ${action.variant === "secondary" ? "btn-secondary" : "btn-primary"}`}
                href={action.href}
              >
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .quote-cta {
    padding-top: 5rem;
  }

  .cta-box {
    background: var(--surface-low);
    padding: clamp(1.6rem, 4vw, 3.2rem);
    text-align: center;
  }

  .cta-box h2 {
    font-size: clamp(1.7rem, 1.2rem + 2vw, 2.55rem);
    color: var(--primary);
    font-style: italic;
  }

  .cta-box p {
    margin-top: 1rem;
    color: var(--text-muted);
  }

  .cta-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }
</style>
