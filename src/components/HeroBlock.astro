---
import { Image, type ImageMetadata } from "astro:assets";

interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  badge: string;
  title: string;
  highlight: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  actions?: Action[];
}

const {
  badge,
  title,
  highlight,
  description,
  image,
  imageAlt,
  actions = [],
} = Astro.props;
---

<section class="hero" id="mediation">
  <div class="container hero-grid">
    <div>
      <div class="badge">{badge}</div>
      <h1>
        {title}
        <span>{highlight}</span>
      </h1>
      <p>{description}</p>
      {
        actions.length > 0 && (
          <div class="hero-cta">
            {actions.map((action) => (
              <a
                class={`btn ${action.variant === "secondary" ? "btn-secondary" : "btn-primary"}`}
                href={action.href}
              >
                {action.label}
              </a>
            ))}
          </div>
        )
      }
    </div>
    <div class="hero-media bubble-card">
      <Image src={image} alt={imageAlt} loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 4.4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    align-items: center;
    gap: 2.1rem;
  }

  h1 {
    font-size: clamp(2.25rem, 1.45rem + 3.2vw, 4.75rem);
    margin: 1.15rem 0 1rem;
  }

  h1 span {
    display: block;
    color: var(--primary);
    font-style: italic;
  }

  p {
    max-width: 56ch;
    font-size: 1.08rem;
    color: var(--text-muted);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }

  .hero-media {
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .hero-media :global(img) {
    aspect-ratio: 4 / 5;
    width: 100%;
    object-fit: cover;
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
