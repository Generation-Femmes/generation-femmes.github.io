---
import { Image } from "astro:assets";
import LogoLarge from "../assets/logo_large.png";
---

<header class="site-header">
  <nav class="container nav-shell" aria-label="Navigation principale">
    <a class="brand" href="/" aria-label="Accueil Génération Femmes">
      <span class="brand-wordmark">
        <Image
          src={LogoLarge}
          alt="Génération Femmes"
          height={58}
          loading="eager"
        />
      </span>
    </a>
    <div class="nav-links">
      <a href="/">Accueil</a>
      <a href="/about">Association</a>
      <a href="/actions">Actions</a>
      <a href="/contact">Contact</a>
    </div>
    <a href="/mediation" class="btn btn-primary nav-cta">Médiation</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.8rem 0;
    backdrop-filter: blur(12px);
    background: rgba(241, 244, 240, 0.88);
    box-shadow: var(--shadow-soft);
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: 1.06rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .brand-wordmark {
    display: inline-flex;
    align-items: center;
    max-width: 340px;
  }

  .brand-wordmark :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .nav-links {
    display: inline-flex;
    align-items: center;
    gap: 1.15rem;
  }

  .nav-links a {
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0.35rem 0.5rem;
    border-radius: 0.7rem;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--text);
    background: rgba(29, 108, 87, 0.11);
  }

  .nav-cta {
    padding: 0.58rem 1.15rem;
    font-size: 0.88rem;
  }

  @media (max-width: 920px) {
    .nav-links {
      display: none;
    }
  }
</style>
