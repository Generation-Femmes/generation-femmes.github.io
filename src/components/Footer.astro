---
import { Image } from "astro:assets";
import LogoLarge from "../assets/logo_large.png";
const today = new Date();
---

<footer class="site-footer" id="contact">
  <div class="container footer-shell">
    <div class="footer-brand">
      <Image
        src={LogoLarge}
        alt="Logo Génération Femmes"
        width={240}
        loading="lazy"
      />
      <h2>Génération Femmes Evry</h2>
      <p>
        La médiation sociale au service de la dignité humaine depuis plus de 30
        ans.
      </p>
    </div>

    <div class="footer-columns">
      <div>
        <h3>Contact</h3>
        <a href="tel:0177970461">01 77 97 04 61</a>
        <a href="mailto:generation-femmes@club-internet.fr"
          >generation-femmes@club-internet.fr</a
        >
      </div>
      <div>
        <h3>Liens</h3>
        <a href="/about">L'association</a>
        <a href="/actions">Nos actions</a>
        <a href="/mediation">Médiation</a>
        <a href="/contact">Nous contacter</a>
      </div>
    </div>

    <div class="footer-legal">
      <p>
        © {today.getFullYear()} Génération Femmes Evry. Tous droits réservés.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 4rem 0;
    background: linear-gradient(
      180deg,
      rgba(225, 235, 229, 0.88),
      rgba(216, 229, 222, 0.96)
    );
    border-top-left-radius: 3rem;
    border-top-right-radius: 3rem;
  }

  .footer-shell {
    display: grid;
    grid-template-columns: 1.2fr 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  .footer-brand h2 {
    font-size: 1.35rem;
    margin-top: 1rem;
    margin-bottom: 0.8rem;
  }

  .footer-brand p {
    max-width: 30ch;
    color: var(--text-muted);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.3rem;
  }

  .footer-columns h3 {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.8rem;
    color: var(--text-muted);
  }

  .footer-columns a {
    display: block;
    text-decoration: none;
    margin-bottom: 0.55rem;
    font-weight: 600;
    color: var(--text);
    opacity: 0.84;
  }

  .footer-columns a:hover {
    opacity: 1;
    color: var(--secondary);
  }

  .footer-legal {
    align-self: end;
    justify-self: end;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .footer-shell {
      grid-template-columns: 1fr;
    }

    .footer-legal {
      justify-self: start;
    }
  }
</style>
